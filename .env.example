# Identity
AGENT_ID=pip
PERSONA_PATH=./personas/pip.json

# Environment server
SERVER_URL=ws://localhost:4001

# Optional admin token. Required by environments that have ADMIN_TOKEN set
# (e.g. 3eyes sim-server when bound to 0.0.0.0). Match exactly to the
# environment server's ADMIN_TOKEN value. Leave empty for localhost-only.
# ADMIN_TOKEN=

# LLM — local Ollama (fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# LLM — cloud (Groq). Strongly recommended. Ollama on a Pi runs at
# ~30s/tick; Groq runs at ~2-3s/tick.
#
# For diligence evaluation: contact Sam (sam.skirrow@gmail.com) for the
# production key. He'll email it when he grants repo access. Alternatively,
# sign up at groq.com (free tier, ~2 minutes, same rate limits) for your own.
# CLOUD_API_KEY=gsk_xxx
# CLOUD_API_URL=https://api.groq.com/openai/v1/chat/completions
# CLOUD_MODEL=openai/gpt-oss-120b
# CLOUD_MODEL_FAST=openai/gpt-oss-20b

# Timing
HEARTBEAT_MS=8000

# Memory
DATA_DIR=./data

# Sleep cycle
# ACTIVE_HOURS_BEFORE_SLEEP=4
# SLEEP_DURATION_MINUTES=60

# API server (each Pi should use a different port if exposed on the same network)
API_PORT=5000

# Logging
# LOG_LEVEL=info
